@page

@using N4Core.Views.Extensions

@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<header>
    <div class="row justify-content-center">
        <div class="col-5">
            <h1>@ViewData["Title"]</h1>
            @{
                if (User.Identity?.IsAuthenticated ?? false)
                {
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.GetHomeRoute()">
                        <button class="w-100 btn btn-lg btn-info" onclick="this.form.submit();">Click here to Logout</button>
                    </form>
                }
                else
                {
                    <p>You have successfully logged out of the application.</p>
                }
            }
        </div>
    </div>
</header>
