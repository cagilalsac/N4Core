@model ViewModel

@{
    var pageNumbers = new SelectList(Model.PageNumbers);
    var recordsPerPageCounts = new SelectList(Model.RecordsPerPageCounts);
    var orderExpressions = new SelectList(Model.OrderExpressions);
}

<hr />
<div class="row" style="padding-top: 15px;padding-bottom: 15px;">
    <div class="col-4">
        <div class="input-group">
            <input asp-for="Filter" class="form-control filter" placeholder="..." id="filter" />
            <button type="submit" class="btn btn-success search" data-bs-toggle="tooltip" title="@Model.ViewTexts.Search" id="search"><i class="bi bi-search"></i></button>
            <a class="btn btn-outline-success clear" data-bs-toggle="tooltip" title="@Model.ViewTexts.Clear" id="clear"><i class="bi bi-arrow-clockwise"></i></a>
        </div>
    </div>
    <div class="col-1 pt-1" style="text-align: right;">
        <label id="recordsperpagecount">...</label>
    </div>
    <div class="col-1">
        <select asp-for="RecordsPerPageCount" class="form-select recordsperpagecount" asp-items="recordsPerPageCounts"></select>
    </div>
    <div class="col-1 pt-1" style="text-align: right;">
        <label id="pagenumber">...</label>
    </div>
    <div class="col-1">
        <select asp-for="PageNumber" class="form-select pagenumber" asp-items="pageNumbers"></select>
    </div>
    @if (orderExpressions is not null && orderExpressions.Any())
    {
        <div class="col-1 order pt-1" style="text-align: right;">
            <label id="orderexpression">...</label>
        </div>
        <div class="col-2 order">
            <select asp-for="OrderExpression" class="form-select orderexpression" asp-items="orderExpressions"></select>
        </div>
        <div class="col-1 order pt-1 ps-4">
            <div class="form-check">
                <input asp-for="OrderDirectionDescending" class="form-check-input orderdirectiondescending" id="orderdirectiondescending">
                <label class="form-check-label" for="orderdirectiondescending" id="orderdirectiondescendinglabel">
                    ...
                </label>
            </div>
        </div>
    }
</div>