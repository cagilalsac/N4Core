@model ViewModel

<div class="col-1 text-end pt-1">
    @Model.ViewTexts.ListView
</div>
<div class="col-2">
    <select name="c" onchange="this.form.submit();" class="form-select">
    @if (Model.ListCards)
    {
        <option value="false">@Model.ViewTexts.ViewList</option>
        <option value="true" selected>@Model.ViewTexts.ViewCards</option>
    }
    else
    {
        <option value="false" selected>@Model.ViewTexts.ViewList</option>
        <option value="true">@Model.ViewTexts.ViewCards</option>
    }
    </select>
</div>