<script>
    $(function () {
        $(".nav-link").click(function (event) {
            event.preventDefault();
            localStorage.setItem("menulinktext", $(this).text());
            window.location.href = $(this).attr("href");
        });
        $(".dropdown-item").click(function (event) {
            event.preventDefault();
            localStorage.setItem("menulinktext", $(this).text());
            window.location.href = $(this).attr("href");
        });
    });
</script>